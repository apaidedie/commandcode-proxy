# ========================================
# 环境变量配置文件
# 复制此文件为 .env 并根据需要修改
# ========================================

# ── 服务配置 ──
# 宿主机端口映射
PROXY_PORT=3050

# 容器内监听端口（通常不需要修改）
PORT=3050

# 监听地址
HOST=0.0.0.0

# ── API 配置 ──
# Command Code API 地址
CC_API_BASE=https://api.commandcode.ai

# 项目标识
PROJECT_SLUG=cc-proxy

# ── 日志配置 ──
# 日志文件路径（空字符串表示只输出到控制台）
LOG_FILE=

# 日志级别: debug | info | warn | error
LOG_LEVEL=info

# ── 模型配置 ──
# 是否动态获取模型列表
CC_USE_PROVIDER_MODELS=true

# ── 其他配置 ──
# 时区设置
TZ=Asia/Shanghai
